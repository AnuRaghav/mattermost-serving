FROM python:3.11-slim-bookworm

WORKDIR /app

COPY requirements.txt requirements-ray.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-ray.txt

COPY app/ ./app/
COPY models/ ./models/
COPY sample_data/ ./sample_data/

ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["python", "-m", "app.ray_serve_app"]
